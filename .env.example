# Database — Neon Postgres
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Cloudinary — video hosting (reused from ../socialMedia/reelGen/.env)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Outstand.so — Instagram posting (reused from reelGen/.env)
OUTSTAND_API_KEY=
OUTSTAND_BASE_URL=https://api.outstand.so/v1

# OpenAI — caption generation
OPENAI_API_KEY=
OPENAI_CAPTION_MODEL=gpt-4o-mini

# Niche config (locked into caption prompt)
NICHE_CITY=Ahmedabad
NICHE_TOPICS=real estate, interior design

# Optional allowlist — only sync these IG handles from Outstand.
# Comma-separated usernames. Leave empty to sync all.
ALLOWED_IG_USERNAMES=

# Auth — single admin-password flow
ADMIN_PASSWORD=change-me
# 32+ char random string — used to sign session cookies (`openssl rand -hex 32`)
SESSION_SECRET=change-me-long-random-string-at-least-32-chars

# Cron endpoint secret — cron-job.org must send header `x-cron-secret: <value>`
CRON_SECRET=change-me-random

# Downloader → API handshake
INGEST_SECRET=change-me-random

# Public URL of the deployed app (used by the local downloader to POST)
NEXT_PUBLIC_APP_URL=http://localhost:3000
