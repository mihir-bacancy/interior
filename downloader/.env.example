# Outstand.so — Instagram posting service (reused from pdfgpt/socialMedia/reelGen)
OUTSTAND_API_KEY=
OUTSTAND_BASE_URL=https://api.outstand.so/v1

# The Outstand account id for the Instagram handle you post to.
# Run `python cli.py accounts` to list connected accounts and set this.
OUTSTAND_IG_ACCOUNT_ID=

# OpenAI — caption generation
OPENAI_API_KEY=
OPENAI_CAPTION_MODEL=gpt-4o-mini

# Niche config (baked into caption prompt)
NICHE_CITY=Ahmedabad
NICHE_TOPICS=real estate, interior design
